{
  "name": "prisma-guard",
  "version": "1.6.0",
  "description": "Prisma generator + runtime for input validation, query shape enforcement, and row-level tenant isolation",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    "./generator": {
      "import": "./dist/generator/index.js",
      "types": "./dist/generator/index.d.ts"
    },
    ".": {
      "import": {
        "types": "./dist/runtime/index.d.ts",
        "default": "./dist/runtime/index.js"
      },
      "require": {
        "types": "./dist/runtime/index.d.cts",
        "default": "./dist/runtime/index.cjs"
      }
    }
  },
  "bin": {
    "prisma-guard": "./dist/generator/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "test:e2e": "npm run build && vitest -c vitest.config.e2e.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/generator-helper": "^6.0.0 || ^7.0.0"
  },
  "peerDependencies": {
    "@prisma/client": "^6.0.0 || ^7.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@prisma/client": "^7.4.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "dotenv": "^16.0.0",
    "prisma": "^7.4.0",
    "semantic-release": "^24.2.9",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0",
    "zod": "^4.3.0"
  }
}
