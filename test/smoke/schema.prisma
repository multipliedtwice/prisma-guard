generator client {
  provider = "prisma-client-js"
}

generator guard {
  provider        = "prisma-guard"
  output          = "generated/guard"
  findUniqueMode  = "reject"
}

datasource db {
  provider = "sqlite"
}

/// @scope-root
model Company {
  id    String @id @default(uuid())
  name  String
  users User[]
}

model User {
  id        String  @id @default(uuid())
  email     String  @unique /// @zod .email()
  name      String?
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
}